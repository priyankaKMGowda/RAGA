# Copy to `.env.local` and fill in your Firebase project credentials.
# Get these from: https://console.firebase.google.com/  → Project settings → Your apps

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — VAPID public key for FCM web push (only required if you wire FCM)
VITE_FIREBASE_VAPID_KEY=

# When unset/empty, the app falls back to a local DEMO auth provider so you
# can run the app without configuring Firebase. Login: demo@medicore.app / demo1234
